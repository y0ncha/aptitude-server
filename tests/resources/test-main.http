### Update lifecycle status
PATCH {{host}}/skills/{{slug}}/versions/{{version}}/status
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "status": "deprecated",
  "note": "Manual frozen-contract lifecycle check."
}

> {%
client.test("status update returns 200", function () {
  client.assert(response.status === 200, "Expected 200, got " + response.status + ": " + response.body);
});
%}
