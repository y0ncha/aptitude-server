# Manual sanity checks for the frozen public contract

@host = http://127.0.0.1:8000
@publisherToken = publisher-token
@readerToken = reader-token
@adminToken = admin-token
@slug = sanity.skill.stub.{{$uuid}}
@version = 1.0.0

### Health
GET {{host}}/healthz
Accept: application/json

> {%
client.test("healthz returns 200", function () {
  client.assert(response.status === 200, "Expected 200, got " + response.status);
});
%}

###

### Readiness
GET {{host}}/readyz
Accept: application/json

> {%
client.test("readyz returns 200", function () {
  client.assert(response.status === 200, "Expected 200, got " + response.status);
});
%}

###

### Publish one immutable version
POST {{host}}/skills/{{slug}}/versions
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{publisherToken}}

{
  "intent": "create_skill",
  "version": "{{version}}",
  "content": {
    "raw_markdown": "# Sanity Skill Stub\n\nManual frozen-contract check.\n"
  },
  "metadata": {
    "name": "Sanity Skill Stub",
    "description": "Manual test for the frozen public contract.",
    "tags": ["sanity", "stub", "manual"],
    "headers": {"runtime": "python"},
    "inputs_schema": {"type": "object"},
    "outputs_schema": {"type": "object"},
    "token_estimate": 64,
    "maturity_score": 0.8,
    "security_score": 0.9
  },
  "governance": {
    "trust_tier": "untrusted",
    "provenance": null
  },
  "relationships": {
    "depends_on": [],
    "extends": [],
    "conflicts_with": [],
    "overlaps_with": []
  }
}

> {%
client.test("publish returns 201", function () {
  client.assert(response.status === 201, "Expected 201, got " + response.status + ": " + response.body);
});
%}

